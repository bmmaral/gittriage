# Local-only; `.nexus/` is gitignored — do not commit the database.
db_path = ".nexus/state.db"
default_roots = ["~/Projects", "~/code"]
github_owner = "your-github-login"
include_hidden = false

[scan]
respect_gitignore = true
max_readme_bytes = 16384
max_hash_files = 64

[planner]
archive_duplicate_threshold = 80
oss_candidate_threshold = 70
# Ambiguous when planner confidence is below this percent (default 60 matches the historical 0.6 cutoff).
ambiguous_cluster_threshold = 60
# Optional: exact clone IDs from `nexus score --format json` to force as canonical within their cluster.
# canonical_pins = ["clone-uuid-here"]
# ignored_cluster_keys = ["name:experiment"]
# archive_hint_cluster_keys = ["name:old-checkout"]
# scoring_profile = "default"
