# Maintainer: submit to AUR with your own maintainer line; this file is upstream reference.
pkgname=gittriage
pkgver=0.1.1
pkgrel=1
pkgdesc='Local-first repo fleet triage CLI'
arch=('x86_64' 'aarch64')
url='https://github.com/bmmaral/gittriage'
license=('MIT')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/bmmaral/gittriage/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('dee91c2c4482c831350bbd15a3144f20ed96ebf0a00e0f7a435974a7a9556ca1')

prepare() {
  cd "$srcdir/gittriage-$pkgver"
}

build() {
  cd "$srcdir/gittriage-$pkgver"
  cargo build --locked --release --package gittriage
}

package() {
  cd "$srcdir/gittriage-$pkgver"
  install -Dm755 target/release/gittriage "$pkgdir/usr/bin/gittriage"
}
